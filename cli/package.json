{
  "name": "@documind/cli",
  "version": "0.2.0",
  "description": "DocuMind real-environment conversation and retrieval diagnostics CLI",
  "type": "module",
  "private": true,
  "bin": {
    "documind": "./src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "check": "tsc --noEmit",
    "test": "bun test",
    "build": "bun build ./src/index.ts --compile --outfile ./dist/documind",
    "verify": "bun run check && bun test && bun run build"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "typescript": "^5.9.3"
  }
}
