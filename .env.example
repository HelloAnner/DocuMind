# ── Database ──
DATABASE_URL=postgres://documind:documind@localhost:5432/documind_dev

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── RabbitMQ ──
RABBITMQ_URL=amqp://localhost:5672

# ── Object Storage (MinIO / S3) ──
OBJECT_STORAGE_PROVIDER=minio
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_BUCKET=documind
OBJECT_STORAGE_ACCESS_KEY=documind
OBJECT_STORAGE_SECRET_KEY=documind
OBJECT_STORAGE_FORCE_PATH_STYLE=true
OBJECT_STORAGE_TLS_VERIFY=false
OBJECT_STORAGE_PRESIGN_EXPIRE_SECONDS=900

# ── LLM Provider ──
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:14b
# Set to true to route generation through the real OpenAI-compatible LLM adapter.
USE_REAL_LLM=false

# ── Embedding ──
EMBEDDING_MODEL=bge-large-zh-v1.5
EMBEDDING_DIM=1024
# EMBEDDING_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/embeddings
ONNX_MODEL_PATH=./models/bge-large-zh-v1.5.onnx

# ── Server ──
SERVER_HOST=0.0.0.0
SERVER_PORT=5555
WEB_OUT_DIR=apps/web/out

# ── Auth ──
JWT_SECRET=change-me-in-production
AUTH_TOKEN_EXPIRE_HOURS=24

# local: use DocuMind's own email/password authentication.
# portal: accept Portal one-time tickets, auto-create/sync local users, then issue a DocuMind session.
AUTH_LOGIN_MODE=local
PORTAL_BASE_URL=http://127.0.0.1:7777
PORTAL_EXCHANGE_ENDPOINT=/api/auth/exchange-ticket

# ── Logging ──
RUST_LOG=documind=debug,tower_http=info
LOG_FORMAT=json

# ── RAG Defaults ──
RAG_REWRITE_ENABLED=true
RAG_HYDE_ENABLED=true
RAG_REWRITE_MODEL=qwen-turbo
RAG_DENSE_TOP_K=100
RAG_BM25_TOP_K=100
RAG_RRF_TOP_K=20
RAG_TOP_K=5
RAG_RERANK_ENABLED=true
RAG_RERANK_MODEL=bge-reranker-v2-m3
RAG_RERANK_THRESHOLD=0.3
RAG_REQUIRE_CITATION=true
RAG_VERIFY_CLAIMS=true
RAG_CHUNK_SIZE=1500
RAG_CHUNK_OVERLAP=200

# ── LLM Generation ──
LLM_TEMPERATURE=0.2
LLM_MAX_OUTPUT_TOKENS=1200

# ── Dev Auth Defaults (used when no JWT/auth middleware is configured) ──
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000002
DEFAULT_ROLE=tenant_admin
DEFAULT_KB_IDS=00000000-0000-0000-0000-000000000003

# ── Agent Policy ──
AGENT_DEFAULT_TONE=concise_warm
AGENT_PROACTIVE_FOLLOWUP=true
AGENT_MAX_FOLLOWUP_SUGGESTIONS=2
AGENT_ALLOW_ANALYST_MODE=true
AGENT_REQUIRE_CITATION_FOR_ANALYSIS=true
AGENT_CLARIFICATION_STYLE=short
