# ── Database ──
DATABASE_URL=postgres://documind:documind@localhost:5432/documind_dev

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── RabbitMQ ──
RABBITMQ_URL=amqp://localhost:5672

# ── Elasticsearch ──
ELASTICSEARCH_URL=http://localhost:9200

# ── Object Storage (MinIO / S3) ──
OBJECT_STORAGE_PROVIDER=minio
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_BUCKET=documind
OBJECT_STORAGE_ACCESS_KEY=documind
OBJECT_STORAGE_SECRET_KEY=documind
OBJECT_STORAGE_FORCE_PATH_STYLE=true
OBJECT_STORAGE_TLS_VERIFY=false
OBJECT_STORAGE_PRESIGN_EXPIRE_SECONDS=900
BLOB_STORAGE_DIR=./data/objects

# ── LLM Provider ──
# Examples:
#   Local Ollama: LLM_BASE_URL=http://localhost:11434/v1
#   DashScope:    LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:14b
# Set to true to route generation through the real OpenAI-compatible LLM adapter.
USE_REAL_LLM=false

# ── Embedding ──
EMBED_MODEL=text-embedding-v3
EMBED_DIM=1024
EMBED_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# EMBED_API_KEY=replace-me
EMBED_BATCH_SIZE=10
EMBED_RETRY_MAX=3
EMBED_WORKER_POLL_MS=1000
EMBED_ENABLED=true
ES_INDEX_CHUNKS=chunks
ES_INDEX_ALIAS=chunks_search
ES_INDEX_SCHEMA_VERSION=2

# ── Server ──
SERVER_HOST=0.0.0.0
SERVER_PORT=8089
WEB_OUT_DIR=apps/web/out

# ── Auth ──
JWT_SECRET=change-me-in-production
AUTH_TOKEN_EXPIRE_HOURS=24

# local: use DocuMind's own email/password authentication.
# portal: accept Portal one-time tickets, auto-create/sync local users, then issue a DocuMind session.
AUTH_LOGIN_MODE=local
PORTAL_BASE_URL=http://127.0.0.1:7777
PORTAL_EXCHANGE_ENDPOINT=/api/auth/exchange-ticket

# ── Logging ──
RUST_LOG=documind=debug,tower_http=info
LOG_FORMAT=json

# ── RAG Defaults ──
RAG_REWRITE_ENABLED=true
RAG_HYDE_ENABLED=true
RAG_REWRITE_MODEL=qwen-turbo
RAG_DENSE_TOP_K=100
RAG_BM25_TOP_K=100
RAG_RRF_TOP_K=20
RAG_TOP_K=5
RAG_TARGET_CHUNK_TOKENS=800
RAG_MAX_CHUNK_TOKENS=1500
RAG_HARD_SPLIT_TOKENS=2000
RAG_MIN_CHUNK_TOKENS=200
RAG_CHUNK_OVERLAP_TOKENS=200
RAG_MAX_TABLE_ROWS_PER_CHUNK=50
RAG_MAX_TABLE_TOKEN_PER_CHUNK=1200
RAG_RERANK_ENABLED=true
RAG_RERANK_PROVIDER=dashscope
RAG_RERANK_MODEL=gte-rerank-v2
# Required in every production deployment; no heuristic rerank fallback exists.
RAG_RERANK_API_URL=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank
RAG_RERANK_API_KEY=
RAG_REQUIRE_CITATION=true
RAG_VERIFY_CLAIMS=true

# ── LLM Generation ──
LLM_TEMPERATURE=0.2
LLM_MAX_OUTPUT_TOKENS=1200

# ── Dev Auth Defaults (used when no JWT/auth middleware is configured) ──
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000002
DEFAULT_ROLE=tenant_admin
DEFAULT_KB_IDS=00000000-0000-0000-0000-000000000003
ENTERPRISE_ADMIN_EMAIL=Anner
ENTERPRISE_ADMIN_PASSWORD=1

# ── Agent Policy ──
AGENT_DEFAULT_TONE=concise_warm
AGENT_REASONING_MODEL=qwen-max
AGENT_PROACTIVE_FOLLOWUP=true
AGENT_MAX_FOLLOWUP_SUGGESTIONS=2
AGENT_ALLOW_ANALYST_MODE=true
AGENT_REQUIRE_CITATION_FOR_ANALYSIS=true
AGENT_CLARIFICATION_STYLE=short
AGENT_MAX_REACT_STEPS=4
AGENT_MAX_QUERIES_PER_STEP=4
AGENT_MAX_HISTORY_TURNS=12
AGENT_MAX_HISTORY_CHARS=24000
AGENT_MAX_CONTEXT_CHARS=30000
AGENT_MAX_REPAIR_ATTEMPTS=3
AGENT_TOTAL_TIMEOUT_SECONDS=240
